# Application
APP_NAME=GenVoice API
APP_VERSION=1.0.0
DEBUG=true

# API
API_V1_PREFIX=/api

# Database (PostgreSQL - Neon)
DATABASE_URL=postgresql://neondb_owner:your_password@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# Database Pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=300
DB_POOL_TIMEOUT=10

# JWT Secret - CHANGE THIS IN PRODUCTION! (min 32 chars recommended)
JWT_SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars

# JWT Settings
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Auth - Google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Auth - Cookie / CSRF
AUTH_COOKIE_NAME=access_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
CSRF_COOKIE_NAME=csrf_token
CSRF_COOKIE_SECURE=false

# Password Requirements
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_LETTER=true
PASSWORD_REQUIRE_NUMBER=true

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://type2vibe.online

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Redis (Upstash)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0
REDIS_SSL=false
REDIS_CONNECT_TIMEOUT=5

# Cloudflare R2 (TTS Models)
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=genvoice-models
R2_ACCOUNT_ID=your_account_id
R2_ENDPOINT_URL=https://your_account_id.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://models.yourdomain.com
SIGNED_URL_EXPIRE_SECONDS=3600

# Cloudflare R2 (Audio Library)
R2_LIBRARY_ACCESS_KEY_ID=your_access_key
R2_LIBRARY_SECRET_ACCESS_KEY=your_secret_key
R2_LIBRARY_BUCKET_NAME=tts-app-library
R2_LIBRARY_PUBLIC_URL=https://library.yourdomain.com

# Quota Management
DEFAULT_QUOTA_TIER=free